    "Install or enable channel plugins on the gateway, then refresh.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Install or enable channel plugins on the gateway, then refresh."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "请在 Gateway 上安装或启用渠道插件，然后刷新。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "請在 Gateway 上安裝或啟用頻道外掛程式，然後重新整理。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Instale ou habilite plugins de canal no gateway e atualize."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Installieren oder aktivieren Sie Kanal-Plugins auf der Gateway und aktualisieren Sie anschließend."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Instala o habilita plugins de canal en el Gateway y luego actualiza."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "Gatewayでチャネルプラグインをインストールまたは有効化してから、更新してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway에서 채널 플러그인을 설치하거나 활성화한 다음 새로 고치세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Installez ou activez les plugins de canaux sur le Gateway, puis actualisez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway पर चैनल प्लगइन इंस्टॉल या सक्षम करें, फिर रीफ़्रेश करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "ثبّت مكوّنات القنوات الإضافية أو فعّلها على Gateway، ثم حدّث."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Installa o abilita i plugin di canale sul gateway, quindi aggiorna."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway'de kanal eklentilerini yükleyin veya etkinleştirin, ardından yenileyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Установіть або ввімкніть плагіни каналів на gateway, а потім оновіть."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Instal atau aktifkan plugin saluran di gateway, lalu segarkan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Zainstaluj lub włącz wtyczki kanałów w Gateway, a następnie odśwież."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "ติดตั้งหรือเปิดใช้งานปลั๊กอินช่องทางบน Gateway แล้วรีเฟรช"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Cài đặt hoặc bật plugin kênh trên gateway, sau đó làm mới."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Installeer of schakel kanaalplug-ins in op de Gateway en vernieuw daarna."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "افزونه‌های کانال را روی Gateway نصب یا فعال کنید، سپس بازآوری کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Установите или включите плагины каналов на gateway, затем обновите."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Installera eller aktivera kanalplugin på Gateway och uppdatera sedan."
          }
        }
      }
    },
