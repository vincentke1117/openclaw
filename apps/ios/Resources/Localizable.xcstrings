          "stringUnit": {
            "state": "new",
            "value": "此裝置不信任 %@ 提供的 TLS 憑證。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Este dispositivo não confia no certificado TLS apresentado por %@."
