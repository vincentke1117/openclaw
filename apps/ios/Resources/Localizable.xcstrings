    "Enabling this sends delivery data through OpenClaw's hosted push relay.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enabling this sends delivery data through OpenClaw's hosted push relay."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "启用此功能会通过 OpenClaw 托管的推送中继发送递送数据。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "啟用此功能會透過 OpenClaw 的託管推播轉送服務傳送通知資料。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Ativar esta opção envia dados de entrega pelo relay de push hospedado da OpenClaw."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Wenn diese Option aktiviert wird, werden Zustelldaten über das von OpenClaw gehostete Push-Relay gesendet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Al habilitar esta opción, los datos de entrega se envían mediante el servicio de retransmisión push alojado de OpenClaw."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "これを有効にすると、配信データがOpenClawのホステッドプッシュリレー経由で送信されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "이 기능을 활성화하면 전송 데이터가 OpenClaw 호스팅 푸시 릴레이를 통해 전송됩니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "L’activation de cette option envoie les données de distribution via le relais de notifications push hébergé d’OpenClaw."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "इसे सक्षम करने पर वितरण डेटा OpenClaw के होस्ट किए गए पुश रिले के माध्यम से भेजा जाता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "يؤدي تمكين هذا الخيار إلى إرسال بيانات التسليم عبر وسيط الإشعارات الفورية المستضاف من OpenClaw."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "L'attivazione di questa opzione invia i dati di consegna tramite il relay push ospitato da OpenClaw."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Bunu etkinleştirmek, iletim verilerini OpenClaw'ın barındırılan anlık bildirim aktarım hizmeti üzerinden gönderir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Якщо ввімкнути цю функцію, дані про доставку надсилатимуться через розміщений OpenClaw ретранслятор push-сповіщень."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Mengaktifkan ini akan mengirimkan data pengiriman melalui relai push yang di-host OpenClaw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Włączenie tej opcji powoduje przesyłanie danych o dostarczeniu przez hostowany przez OpenClaw przekaźnik powiadomień push."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "การเปิดใช้งานตัวเลือกนี้จะส่งข้อมูลการส่งผ่านรีเลย์พุชที่โฮสต์โดย OpenClaw"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Việc bật tùy chọn này sẽ gửi dữ liệu gửi thông báo qua dịch vụ chuyển tiếp thông báo đẩy do OpenClaw lưu trữ."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Als u dit inschakelt, worden bezorgingsgegevens via de gehoste pushrelay van OpenClaw verzonden."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "با فعال‌سازی این گزینه، داده‌های تحویل از طریق رله پوش میزبانی‌شده OpenClaw ارسال می‌شوند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "При включении данные о доставке будут передаваться через размещённый сервис ретрансляции push-уведомлений OpenClaw."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Om du aktiverar detta skickas leveransdata via OpenClaws driftade push-relä."
          }
        }
      }
    },
