          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Cet appareil ne fait pas confiance au certificat TLS présenté par %@."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "यह डिवाइस %@ द्वारा प्रस्तुत TLS सर्टिफ़िकेट पर भरोसा नहीं करता।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
