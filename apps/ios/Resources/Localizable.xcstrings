    "Connection timed out. Make sure Tailscale is connected, then try again.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connection timed out. Make sure Tailscale is connected, then try again."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "连接超时。请确保 Tailscale 已连接，然后重试。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "連線逾時。請確認 Tailscale 已連線，然後再試一次。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "A conexão expirou. Verifique se o Tailscale está conectado e tente novamente."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Zeitüberschreitung bei der Verbindung. Stellen Sie sicher, dass Tailscale verbunden ist, und versuchen Sie es erneut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Se agotó el tiempo de espera de la conexión. Asegúrate de que Tailscale esté conectado y vuelve a intentarlo."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "接続がタイムアウトしました。Tailscaleが接続されていることを確認してから、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "연결 시간이 초과되었습니다. Tailscale이 연결되어 있는지 확인한 다음 다시 시도하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Délai de connexion dépassé. Vérifiez que Tailscale est connecté, puis réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "कनेक्शन का समय समाप्त हो गया। सुनिश्चित करें कि Tailscale कनेक्टेड है, फिर दोबारा कोशिश करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "انتهت مهلة الاتصال. تأكّد من اتصال Tailscale، ثم حاول مجددًا."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Connessione scaduta. Assicurati che Tailscale sia connesso, quindi riprova."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Bağlantı zaman aşımına uğradı. Tailscale'in bağlı olduğundan emin olun, ardından tekrar deneyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Час очікування з’єднання минув. Переконайтеся, що Tailscale підключено, а потім повторіть спробу."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Waktu koneksi habis. Pastikan Tailscale terhubung, lalu coba lagi."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Upłynął limit czasu połączenia. Upewnij się, że Tailscale jest połączony, a następnie spróbuj ponownie."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "หมดเวลาการเชื่อมต่อ ตรวจสอบให้แน่ใจว่า Tailscale เชื่อมต่ออยู่ แล้วลองอีกครั้ง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Kết nối đã hết thời gian chờ. Hãy đảm bảo Tailscale đã kết nối, sau đó thử lại."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Time-out bij verbinding. Controleer of Tailscale verbonden is en probeer het opnieuw."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "زمان اتصال به پایان رسید. مطمئن شوید Tailscale متصل است، سپس دوباره تلاش کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Время ожидания подключения истекло. Убедитесь, что Tailscale подключён, затем повторите попытку."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Anslutningen nådde tidsgränsen. Kontrollera att Tailscale är anslutet och försök sedan igen."
          }
        }
      }
    },
