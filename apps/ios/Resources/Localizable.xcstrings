    "The session and its transcript are removed from the gateway.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The session and its transcript are removed from the gateway."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "会话及其转录记录已从 Gateway 中移除。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "工作階段及其記錄將從 gateway 移除。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "A sessão e sua transcrição são removidas do gateway."
          }
        },
