        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "स्थान साझा करने के लिए iOS अनुमति आवश्यक है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "يلزم إذن iOS لمشاركة الموقع."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "È richiesta l'autorizzazione di iOS per condividere la posizione."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Konum paylaşmak için iOS izni gerekli."
