          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Aucun signal récent de rappel, quotidien, ancré ou de phase n’a été signalé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "कोई हालिया रिकॉल, दैनिक, grounded, या phase संकेत रिपोर्ट नहीं किए गए।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
