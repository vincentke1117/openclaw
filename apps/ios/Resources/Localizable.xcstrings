    "Plaintext may expose credentials. Continue only if you trust this local network and host.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plaintext may expose credentials. Continue only if you trust this local network and host."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "明文可能会暴露凭据。仅在你信任此本地网络和主机时继续。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "純文字可能會暴露憑證。只有在您信任此本機網路和主機時才繼續。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Texto simples pode expor credenciais. Continue apenas se você confia nesta rede local e neste host."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Klartext kann Zugangsdaten offenlegen. Fahren Sie nur fort, wenn Sie diesem lokalen Netzwerk und Host vertrauen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "El texto sin formato puede exponer las credenciales. Continúa solo si confías en esta red local y en el host."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "プレーンテキストでは認証情報が公開される可能性があります。このローカルネットワークとホストを信頼できる場合にのみ続行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "일반 텍스트는 자격 증명을 노출할 수 있습니다. 이 로컬 네트워크와 호스트를 신뢰하는 경우에만 계속하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Le texte en clair peut exposer les identifiants. Continuez uniquement si vous faites confiance à ce réseau local et à cet hôte."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "सादा टेक्स्ट क्रेडेंशियल्स को उजागर कर सकता है। केवल तभी जारी रखें जब आप इस स्थानीय नेटवर्क और होस्ट पर भरोसा करते हों।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "قد يكشف النص العادي بيانات الاعتماد. تابع فقط إذا كنت تثق بهذه الشبكة المحلية وهذا المضيف."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Il testo in chiaro può esporre le credenziali. Continua solo se consideri attendibili questa rete locale e questo host."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Düz metin kimlik bilgilerini açığa çıkarabilir. Yalnızca bu yerel ağa ve ana makineye güveniyorsanız devam edin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Відкритий текст може розкрити облікові дані. Продовжуйте лише якщо ви довіряєте цій локальній мережі та хосту."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Teks biasa dapat mengekspos kredensial. Lanjutkan hanya jika Anda memercayai jaringan lokal dan host ini."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Tekst jawny może ujawnić dane uwierzytelniające. Kontynuuj tylko wtedy, gdy ufasz tej sieci lokalnej i hostowi."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "ข้อความธรรมดาอาจเปิดเผยข้อมูลประจำตัวได้ ดำเนินการต่อเฉพาะเมื่อคุณเชื่อถือเครือข่ายภายในและโฮสต์นี้เท่านั้น"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Văn bản thuần có thể làm lộ thông tin đăng nhập. Chỉ tiếp tục nếu bạn tin tưởng mạng cục bộ và máy chủ này."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Platte tekst kan inloggegevens blootstellen. Ga alleen verder als je dit lokale netwerk en deze host vertrouwt."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "متن ساده ممکن است اطلاعات ورود را افشا کند. فقط در صورتی ادامه دهید که به این شبکهٔ محلی و میزبان اعتماد دارید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Открытый текст может раскрыть учетные данные. Продолжайте, только если вы доверяете этой локальной сети и хосту."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Klartext kan exponera inloggningsuppgifter. Fortsätt endast om du litar på det här lokala nätverket och värden."
          }
        }
      }
    },
