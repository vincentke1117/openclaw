    "This device does not trust the TLS certificate presented by %@.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This device does not trust the TLS certificate presented by %@."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "此设备不信任 %@ 提供的 TLS 证书。"
          }
        },
