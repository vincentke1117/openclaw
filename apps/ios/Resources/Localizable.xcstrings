    "No secure gateway endpoint was detected at %1$@:%2$@. Enable gateway TLS or Tailscale Serve, or use a trusted private LAN address with Unencrypted selected.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No secure gateway endpoint was detected at %1$@:%2$@. Enable gateway TLS or Tailscale Serve, or use a trusted private LAN address with Unencrypted selected."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "未在 %1$@:%2$@ 检测到安全的 Gateway 端点。请启用 Gateway TLS 或 Tailscale Serve，或者选择“未加密”并使用受信任的专用局域网地址。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "在 %1$@:%2$@ 未偵測到安全的 Gateway 端點。請啟用 Gateway TLS 或 Tailscale Serve，或選取「未加密」並使用受信任的私人 LAN 位址。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Nenhum endpoint seguro do Gateway foi detectado em %1$@:%2$@. Ative o TLS do Gateway ou o Tailscale Serve, ou use um endereço de LAN privada confiável com Não criptografado selecionado."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Unter %1$@:%2$@ wurde kein sicherer Gateway-Endpunkt erkannt. Aktiviere Gateway-TLS oder Tailscale Serve oder verwende eine vertrauenswürdige private LAN-Adresse mit ausgewählter Option „Unverschlüsselt“."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "No se detectó ningún punto de conexión seguro del Gateway en %1$@:%2$@. Activa TLS del Gateway o Tailscale Serve, o usa una dirección LAN privada de confianza con Sin cifrar seleccionado."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@:%2$@でセキュアなGatewayエンドポイントが検出されませんでした。Gateway TLSまたはTailscale Serveを有効にするか、Unencryptedを選択して信頼できるプライベートLANアドレスを使用してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@:%2$@에서 보안 Gateway 엔드포인트가 감지되지 않았습니다. Gateway TLS 또는 Tailscale Serve를 활성화하거나, 신뢰할 수 있는 비공개 LAN 주소를 사용하고 암호화되지 않음을 선택하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Aucun point de terminaison sécurisé du Gateway n’a été détecté à l’adresse %1$@:%2$@. Activez TLS sur le Gateway ou Tailscale Serve, ou utilisez une adresse de réseau local privé de confiance avec l’option Non chiffré sélectionnée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@:%2$@ पर कोई सुरक्षित Gateway एंडपॉइंट नहीं मिला। Gateway TLS या Tailscale Serve सक्षम करें, या Unencrypted चयनित करके किसी विश्वसनीय निजी LAN पते का उपयोग करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "لم يتم اكتشاف نقطة نهاية آمنة لـ Gateway على %1$@:%2$@. فعّل TLS لـ Gateway أو Tailscale Serve، أو استخدم عنوان LAN خاصًا وموثوقًا مع تحديد «غير مشفّر»."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Non è stato rilevato alcun endpoint sicuro del Gateway all'indirizzo %1$@:%2$@. Abilita TLS per il Gateway o Tailscale Serve, oppure usa un indirizzo LAN privato attendibile con Non crittografato selezionato."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@:%2$@ adresinde güvenli bir Gateway uç noktası algılanmadı. Gateway TLS'yi veya Tailscale Serve'ü etkinleştirin ya da Şifrelenmemiş seçiliyken güvenilir bir özel LAN adresi kullanın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "За адресою %1$@:%2$@ не виявлено захищеної кінцевої точки шлюзу. Увімкніть TLS шлюзу або Tailscale Serve чи використайте довірену адресу приватної локальної мережі з вибраним параметром «Без шифрування»."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Tidak ada endpoint gateway aman yang terdeteksi di %1$@:%2$@. Aktifkan TLS gateway atau Tailscale Serve, atau gunakan alamat LAN privat tepercaya dengan opsi Tidak Terenkripsi dipilih."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Nie wykryto bezpiecznego punktu końcowego Gateway pod adresem %1$@:%2$@. Włącz TLS Gateway lub Tailscale Serve albo użyj zaufanego adresu prywatnej sieci LAN z wybraną opcją Nieszyfrowane."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "ไม่พบปลายทาง Gateway ที่ปลอดภัยที่ %1$@:%2$@ เปิดใช้งาน TLS ของ Gateway หรือ Tailscale Serve หรือใช้ที่อยู่ LAN ส่วนตัวที่เชื่อถือได้โดยเลือกไม่ได้เข้ารหัส"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Không phát hiện thấy điểm cuối Gateway bảo mật tại %1$@:%2$@. Hãy bật TLS cho Gateway hoặc Tailscale Serve, hoặc sử dụng địa chỉ mạng LAN riêng tư đáng tin cậy và chọn Unencrypted."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Er is geen beveiligd gateway-eindpunt gedetecteerd op %1$@:%2$@. Schakel TLS voor de gateway of Tailscale Serve in, of gebruik een vertrouwd privé-LAN-adres met Onversleuteld geselecteerd."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "هیچ نقطه پایانی امنی برای Gateway در %1$@:%2$@ شناسایی نشد. TLS مربوط به Gateway یا Tailscale Serve را فعال کنید، یا با انتخاب Unencrypted از یک نشانی خصوصی و قابل‌اعتماد در شبکه محلی استفاده کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "По адресу %1$@:%2$@ не обнаружена защищённая конечная точка Gateway. Включите TLS для Gateway или Tailscale Serve либо используйте доверенный адрес частной локальной сети, выбрав «Без шифрования»."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Ingen säker Gateway-slutpunkt identifierades på %1$@:%2$@. Aktivera TLS för Gateway eller Tailscale Serve, eller använd en betrodd privat LAN-adress med Okrypterad valt."
          }
        }
      }
    },
