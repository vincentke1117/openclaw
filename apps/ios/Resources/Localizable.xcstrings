    "Sent with foreground app connections to this gateway. Changes apply on the next reconnect; Share extension delivery is not yet supported.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sent with foreground app connections to this gateway. Changes apply on the next reconnect; Share extension delivery is not yet supported."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "随前台应用连接发送到此 Gateway。更改将在下次重新连接时生效；尚不支持 Share 扩展递送。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "透過前景應用程式連線傳送至此 gateway。變更會在下次重新連線時套用；尚未支援 Share extension 傳送。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Enviado com conexões do app em primeiro plano para este gateway. As alterações serão aplicadas na próxima reconexão; a entrega pela extensão de compartilhamento ainda não é compatível."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Wird bei Verbindungen der Vordergrund-App zu dieser Gateway gesendet. Änderungen werden beim nächsten erneuten Verbinden angewendet; die Zustellung über die Share-Erweiterung wird noch nicht unterstützt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Se envía con las conexiones de la app en primer plano a este gateway. Los cambios se aplican en la próxima reconexión; la entrega mediante la extensión para compartir aún no es compatible."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "このGatewayへのフォアグラウンドアプリ接続で送信されます。変更は次回の再接続時に適用されます。Share拡張機能による配信はまだサポートされていません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "이 Gateway에 대한 포그라운드 앱 연결과 함께 전송됩니다. 변경 사항은 다음 재연결 시 적용되며, Share extension 전달은 아직 지원되지 않습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Envoyé avec les connexions de l’app au premier plan à cette Gateway. Les modifications s’appliquent à la prochaine reconnexion ; la livraison via l’extension de partage n’est pas encore prise en charge."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "इस Gateway पर अग्रभूमि ऐप कनेक्शन के साथ भेजा गया। बदलाव अगले रीकनेक्ट पर लागू होंगे; Share extension डिलीवरी अभी समर्थित नहीं है."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "تُرسل مع اتصالات التطبيق في الواجهة الأمامية إلى هذا Gateway. تُطبَّق التغييرات عند إعادة الاتصال التالية؛ تسليم امتداد المشاركة غير مدعوم بعد."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Inviate con le connessioni dell’app in primo piano a questo Gateway. Le modifiche si applicano alla prossima riconnessione; la consegna tramite estensione di condivisione non è ancora supportata."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Bu Gateway'e ön plandaki uygulama bağlantılarıyla gönderilir. Değişiklikler bir sonraki yeniden bağlantıda uygulanır; Share extension ile teslim henüz desteklenmiyor."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Надсилаються через підключення активного застосунку до цього Gateway. Зміни застосуються під час наступного повторного підключення; доставка через розширення Share ще не підтримується."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Dikirim dengan koneksi aplikasi latar depan ke gateway ini. Perubahan berlaku pada penyambungan ulang berikutnya; pengiriman ekstensi Berbagi belum didukung."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Wysyłane z połączeniami aplikacji na pierwszym planie do tego gateway. Zmiany zostaną zastosowane przy następnym ponownym połączeniu; dostarczanie przez rozszerzenie Share nie jest jeszcze obsługiwane."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "ส่งพร้อมกับการเชื่อมต่อของแอปเบื้องหน้าไปยัง Gateway นี้ การเปลี่ยนแปลงจะมีผลเมื่อเชื่อมต่อใหม่ครั้งถัดไป ยังไม่รองรับการส่งผ่าน Share extension"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Được gửi cùng với các kết nối ứng dụng ở nền trước tới gateway này. Các thay đổi sẽ áp dụng vào lần kết nối lại tiếp theo; tính năng gửi qua Share extension chưa được hỗ trợ."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Verzonden met verbindingen van de app op de voorgrond naar deze gateway. Wijzigingen worden toegepast bij de volgende herverbinding; levering via de Share-extensie wordt nog niet ondersteund."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "با اتصال‌های برنامه در پیش‌زمینه به این gateway ارسال می‌شود. تغییرات در اتصال مجدد بعدی اعمال می‌شوند؛ تحویل از طریق افزونه اشتراک‌گذاری هنوز پشتیبانی نمی‌شود."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Отправляются через подключения активного приложения к этому Gateway. Изменения применятся при следующем повторном подключении; доставка через расширение «Поделиться» пока не поддерживается."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Skickas med appanslutningar i förgrunden till denna gateway. Ändringar gäller vid nästa återanslutning; leverans via delningstillägg stöds inte ännu."
          }
        }
      }
    },
