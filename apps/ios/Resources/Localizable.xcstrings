    "Enable “Discovery Debug Logs” to start collecting events.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable “Discovery Debug Logs” to start collecting events."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "启用“Discovery Debug Logs”以开始收集事件。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "啟用「Discovery Debug Logs」以開始收集事件。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Ative “Discovery Debug Logs” para começar a coletar eventos."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Aktivieren Sie „Discovery Debug Logs“, um mit der Erfassung von Ereignissen zu beginnen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Activa “Registros de depuración de Discovery” para empezar a recopilar eventos."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "イベントの収集を開始するには「Discovery Debug Logs」を有効にしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "이벤트 수집을 시작하려면 “Discovery Debug Logs”를 활성화하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Activez « Discovery Debug Logs » pour commencer à collecter des événements."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "इवेंट्स एकत्र करना शुरू करने के लिए “Discovery Debug Logs” सक्षम करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "فعّل “Discovery Debug Logs” لبدء جمع الأحداث."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Abilita “Discovery Debug Logs” per iniziare a raccogliere eventi."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Etkinlikleri toplamaya başlamak için “Discovery Debug Logs” özelliğini etkinleştirin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Увімкніть «Discovery Debug Logs», щоб почати збирати події."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Aktifkan “Discovery Debug Logs” untuk mulai mengumpulkan peristiwa."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Włącz „Discovery Debug Logs”, aby rozpocząć zbieranie zdarzeń."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "เปิดใช้ “Discovery Debug Logs” เพื่อเริ่มรวบรวมเหตุการณ์"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Bật “Discovery Debug Logs” để bắt đầu thu thập sự kiện."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Schakel “Discovery Debug Logs” in om gebeurtenissen te verzamelen."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "برای شروع جمع‌آوری رویدادها، «Discovery Debug Logs» را فعال کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Включите «Discovery Debug Logs», чтобы начать сбор событий."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Aktivera ”Discovery Debug Logs” för att börja samla in händelser."
          }
        }
      }
    },
