    "This approval was already set to Always Allow.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This approval was already set to Always Allow."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "此审批已设置为始终允许。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "此核准已設為永遠允許。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Esta aprovação já estava definida como Permitir sempre."
