    "Continue only if you trust the gateway and agent you connect to.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Continue only if you trust the gateway and agent you connect to."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "仅在你信任所连接的 gateway 和 agent 时继续。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "只有在你信任所連線的 gateway 和代理程式時才繼續。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Continue somente se você confiar no gateway e no agente aos quais se conectar."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Fahren Sie nur fort, wenn Sie dem Gateway und dem Agenten vertrauen, mit denen Sie sich verbinden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Continúa solo si confías en el gateway y el agente a los que te conectas."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "接続先のGatewayとエージェントを信頼できる場合のみ続行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "연결하려는 gateway와 에이전트를 신뢰하는 경우에만 계속하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Continuez uniquement si vous faites confiance au gateway et à l’agent auxquels vous vous connectez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "केवल तभी जारी रखें जब आप उस gateway और एजेंट पर भरोसा करते हों जिससे आप कनेक्ट कर रहे हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "تابع فقط إذا كنت تثق في gateway والوكيل اللذين تتصل بهما."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Continua solo se consideri attendibili il gateway e l'agente a cui ti connetti."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Yalnızca bağlandığınız gateway’e ve aracıya güveniyorsanız devam edin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Продовжуйте лише якщо довіряєте gateway та агенту, до яких підключаєтеся."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Lanjutkan hanya jika Anda memercayai gateway dan agen yang Anda hubungkan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Kontynuuj tylko wtedy, gdy ufasz gateway i agentowi, z którymi się łączysz."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "ดำเนินการต่อเฉพาะเมื่อคุณเชื่อถือ gateway และเอเจนต์ที่คุณเชื่อมต่ออยู่"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Chỉ tiếp tục nếu bạn tin tưởng gateway và tác nhân mà bạn kết nối."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Ga alleen door als je de gateway en agent vertrouwt waarmee je verbinding maakt."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "فقط در صورتی ادامه دهید که به gateway و عاملی که به آن متصل می‌شوید اعتماد دارید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Продолжайте, только если доверяете gateway и агенту, к которым подключаетесь."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Fortsätt endast om du litar på den gateway och agent du ansluter till."
          }
        }
      }
    },
