          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Abilita le notifiche per ricevere richieste di approvazione e avvisi di eventi fuori dall'app."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Uygulama dışında onay istemleri ve olay uyarıları almak için bildirimleri etkinleştirin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Увімкніть сповіщення, щоб отримувати запити на підтвердження та сповіщення про події поза застосунком."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Aktifkan notifikasi untuk menerima permintaan persetujuan dan peringatan peristiwa di luar aplikasi."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Włącz powiadomienia, aby otrzymywać monity o zatwierdzenie i alerty o zdarzeniach poza aplikacją."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "เปิดใช้งานการแจ้งเตือนเพื่อรับคำขออนุมัติและการแจ้งเตือนเหตุการณ์นอกแอป"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Bật thông báo để nhận lời nhắc phê duyệt và cảnh báo sự kiện bên ngoài ứng dụng."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Schakel meldingen in om goedkeuringsvragen en gebeurtenismeldingen buiten de app te ontvangen."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "اعلان‌ها را فعال کنید تا درخواست‌های تأیید و هشدارهای رویداد را خارج از برنامه دریافت کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Включите уведомления, чтобы получать запросы на подтверждение и оповещения о событиях вне приложения."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Aktivera aviseringar för att få godkännandeförfrågningar och händelseaviseringar utanför appen."
          }
        }
      }
    },
