    "Gateway approval is required before this phone can capture voice.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway approval is required before this phone can capture voice."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "此手机需要获得 Gateway 批准后才能采集语音。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "此手機必須先獲得 Gateway 核准，才能擷取語音。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "A aprovação do Gateway é necessária para que este telefone possa capturar voz."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Die Genehmigung durch das Gateway ist erforderlich, bevor dieses Telefon Sprache erfassen kann."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Se requiere la aprobación del Gateway para que este teléfono pueda capturar voz."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "この電話で音声をキャプチャするには、Gatewayの承認が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "이 휴대폰에서 음성을 캡처하려면 Gateway 승인이 필요합니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "L’approbation du Gateway est requise avant que ce téléphone puisse enregistrer la voix."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "यह फ़ोन वॉइस कैप्चर कर सके, इससे पहले Gateway की मंज़ूरी आवश्यक है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "يلزم الحصول على موافقة Gateway قبل أن يتمكن هذا الهاتف من التقاط الصوت."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "È necessaria l'approvazione del Gateway prima che questo telefono possa acquisire la voce."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Bu telefonun ses yakalayabilmesi için Gateway onayı gereklidir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Перш ніж цей телефон зможе записувати голос, потрібне схвалення Gateway."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Persetujuan Gateway diperlukan sebelum ponsel ini dapat merekam suara."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Zanim ten telefon będzie mógł przechwytywać głos, wymagane jest zatwierdzenie przez Gateway."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "ต้องได้รับการอนุมัติจาก Gateway ก่อนที่โทรศัพท์เครื่องนี้จะสามารถบันทึกเสียงได้"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Cần có sự phê duyệt của Gateway trước khi điện thoại này có thể thu âm giọng nói."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Goedkeuring van de gateway is vereist voordat deze telefoon spraak kan opnemen."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "پیش از اینکه این تلفن بتواند صدا را ضبط کند، تأیید Gateway لازم است."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Прежде чем этот телефон сможет записывать голос, требуется одобрение Gateway."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Godkännande från Gateway krävs innan den här telefonen kan spela in röst."
          }
        }
      }
    },
