    "Review this endpoint. Credentials are applied only after you tap Connect.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Review this endpoint. Credentials are applied only after you tap Connect."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "请检查此端点。凭据仅在你轻点“连接”后应用。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "請檢查此端點。只有在您點一下「連線」後，才會套用憑證。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Revise este endpoint. As credenciais são aplicadas somente depois que você tocar em Conectar."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Prüfen Sie diesen Endpunkt. Zugangsdaten werden erst angewendet, nachdem Sie auf „Verbinden“ tippen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Revisa este endpoint. Las credenciales se aplican solo después de que toques Conectar."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "このエンドポイントを確認してください。認証情報は「接続」をタップした後にのみ適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "이 엔드포인트를 검토하세요. 자격 증명은 연결을 탭한 후에만 적용됩니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Vérifiez ce point de terminaison. Les identifiants ne sont appliqués qu’après avoir touché Connecter."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "इस एंडपॉइंट की समीक्षा करें। क्रेडेंशियल्स केवल तब लागू होते हैं जब आप Connect पर टैप करते हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "راجع نقطة النهاية هذه. لا تُطبَّق بيانات الاعتماد إلا بعد النقر على اتصال."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Controlla questo endpoint. Le credenziali vengono applicate solo dopo aver toccato Connetti."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Bu uç noktayı gözden geçirin. Kimlik bilgileri yalnızca Bağlan’a dokunduktan sonra uygulanır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Перевірте цей кінцевий вузол. Облікові дані застосовуються лише після того, як ви торкнетеся «Підключити»."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Tinjau endpoint ini. Kredensial hanya diterapkan setelah Anda mengetuk Hubungkan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Sprawdź ten punkt końcowy. Dane uwierzytelniające zostaną zastosowane dopiero po stuknięciu Połącz."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "ตรวจสอบเอ็นด์พอยต์นี้ ข้อมูลประจำตัวจะถูกนำไปใช้หลังจากที่คุณแตะเชื่อมต่อเท่านั้น"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Xem lại điểm cuối này. Thông tin đăng nhập chỉ được áp dụng sau khi bạn nhấn Kết nối."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Controleer dit eindpunt. Inloggegevens worden pas toegepast nadat je op Verbind tikt."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "این نقطهٔ پایانی را بازبینی کنید. اطلاعات ورود فقط پس از لمس «اتصال» اعمال می‌شوند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Проверьте эту конечную точку. Учетные данные будут применены только после нажатия Connect."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Granska den här ändpunkten. Inloggningsuppgifter tillämpas först efter att du trycker på Anslut."
          }
        }
      }
    },
