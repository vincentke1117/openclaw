    "Keep your iPhone on the same LAN or tailnet, then start the Gateway on your host machine.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep your iPhone on the same LAN or tailnet, then start the Gateway on your host machine."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "请让你的 iPhone 保持在同一 LAN 或 tailnet 中，然后在主机上启动 Gateway。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "讓你的 iPhone 保持在相同的 LAN 或 tailnet 上，然後在主機上啟動 Gateway。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Mantenha seu iPhone na mesma LAN ou tailnet e, em seguida, inicie o Gateway na sua máquina host."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Lassen Sie Ihr iPhone im selben LAN oder Tailnet und starten Sie dann die Gateway auf Ihrem Host-Computer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Mantén tu iPhone en la misma LAN o tailnet y, luego, inicia el Gateway en tu equipo host."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "iPhoneを同じLANまたはtailnet上に置いたままにしてから、ホストマシンでGatewayを起動してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "iPhone을 동일한 LAN 또는 tailnet에 유지한 다음, 호스트 머신에서 Gateway를 시작하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Gardez votre iPhone sur le même LAN ou tailnet, puis démarrez le Gateway sur votre machine hôte."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "अपने iPhone को उसी LAN या tailnet पर रखें, फिर अपनी होस्ट मशीन पर Gateway शुरू करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "أبقِ iPhone على نفس شبكة LAN أو tailnet، ثم ابدأ Gateway على جهازك المضيف."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Mantieni il tuo iPhone sulla stessa LAN o tailnet, quindi avvia il Gateway sul tuo computer host."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "iPhone’unuzu aynı LAN veya tailnet üzerinde tutun, ardından ana makinenizde Gateway’i başlatın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Тримайте iPhone у тій самій LAN або tailnet, а потім запустіть Gateway на хост-комп’ютері."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Biarkan iPhone Anda berada di LAN atau tailnet yang sama, lalu mulai Gateway di mesin host Anda."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Trzymaj iPhone’a w tej samej sieci LAN lub tailnet, a następnie uruchom Gateway na komputerze hosta."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "ให้ iPhone ของคุณอยู่บน LAN หรือ tailnet เดียวกัน จากนั้นเริ่ม Gateway บนเครื่องโฮสต์ของคุณ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Giữ iPhone của bạn trên cùng mạng LAN hoặc tailnet, rồi khởi động Gateway trên máy chủ của bạn."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Houd je iPhone op hetzelfde LAN of tailnet en start vervolgens de Gateway op je hostmachine."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "iPhone خود را روی همان LAN یا tailnet نگه دارید، سپس Gateway را روی دستگاه میزبان خود راه‌اندازی کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Держите iPhone в той же LAN или tailnet, затем запустите Gateway на хост-компьютере."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Ha din iPhone på samma LAN eller tailnet och starta sedan Gateway på din värddator."
          }
        }
      }
    },
