{
  "sourceLanguage": "en",
  "strings": {
    " The new certificate is trusted by this device; this is commonly caused by certificate rotation.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": " The new certificate is trusted by this device; this is commonly caused by certificate rotation."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": " 新证书受此设备信任；这通常是由证书轮换引起的。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": " 新憑證受到此裝置信任；這通常是由憑證輪替所導致。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": " O novo certificado é confiável para este dispositivo; isso geralmente é causado pela rotação de certificados."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": " Das neue Zertifikat wird von diesem Gerät als vertrauenswürdig eingestuft; dies wird häufig durch Zertifikatsrotation verursacht."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": " El nuevo certificado es de confianza para este dispositivo; esto suele deberse a la rotación de certificados."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": " 新しい証明書はこのデバイスで信頼されています。これは通常、証明書のローテーションが原因です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": " 새 인증서는 이 기기에서 신뢰됩니다. 이는 일반적으로 인증서 교체로 인해 발생합니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": " Le nouveau certificat est approuvé par cet appareil ; cela est généralement dû à une rotation de certificat."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": " नया प्रमाणपत्र इस डिवाइस द्वारा विश्वसनीय है; यह आमतौर पर प्रमाणपत्र रोटेशन के कारण होता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": " الشهادة الجديدة موثوق بها على هذا الجهاز؛ يحدث هذا عادةً بسبب تدوير الشهادة."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": " Il nuovo certificato è considerato attendibile da questo dispositivo; questo è comunemente causato dalla rotazione dei certificati."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": " Yeni sertifika bu cihaz tarafından güvenilir kabul ediliyor; bu genellikle sertifika rotasyonundan kaynaklanır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": " Новий сертифікат є довіреним на цьому пристрої; зазвичай це спричинено ротацією сертифіката."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": " Sertifikat baru dipercaya oleh perangkat ini; hal ini biasanya disebabkan oleh rotasi sertifikat."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": " Nowy certyfikat jest zaufany przez to urządzenie; zwykle jest to spowodowane rotacją certyfikatu."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": " ใบรับรองใหม่ได้รับความเชื่อถือจากอุปกรณ์นี้ ซึ่งมักเกิดจากการหมุนเวียนใบรับรอง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": " Chứng chỉ mới được thiết bị này tin cậy; điều này thường do xoay vòng chứng chỉ gây ra."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": " Het nieuwe certificaat wordt door dit apparaat vertrouwd; dit wordt meestal veroorzaakt door certificaatrotatie."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": " گواهی جدید مورد اعتماد این دستگاه است؛ این معمولاً به دلیل چرخش گواهی رخ می‌دهد."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": " Новый сертификат является доверенным для этого устройства; обычно это вызвано ротацией сертификата."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": " Det nya certifikatet är betrott av den här enheten; detta orsakas ofta av certifikatrotation."
          }
        }
      }
    },
    " This device could not verify the new certificate.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": " This device could not verify the new certificate."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": " 此设备无法验证新证书。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": " 此裝置無法驗證新憑證。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": " Este dispositivo não pôde verificar o novo certificado."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": " Dieses Gerät konnte das neue Zertifikat nicht verifizieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": " Este dispositivo no pudo verificar el nuevo certificado."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": " このデバイスでは新しい証明書を確認できませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": " 이 기기에서 새 인증서를 확인할 수 없습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": " Cet appareil n’a pas pu vérifier le nouveau certificat."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": " यह डिवाइस नए प्रमाणपत्र को सत्यापित नहीं कर सका।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": " تعذّر على هذا الجهاز التحقق من الشهادة الجديدة."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": " Questo dispositivo non ha potuto verificare il nuovo certificato."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": " Bu cihaz yeni sertifikayı doğrulayamadı."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": " Цей пристрій не зміг перевірити новий сертифікат."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": " Perangkat ini tidak dapat memverifikasi sertifikat baru."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": " To urządzenie nie mogło zweryfikować nowego certyfikatu."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": " อุปกรณ์นี้ไม่สามารถตรวจสอบใบรับรองใหม่ได้"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": " Thiết bị này không thể xác minh chứng chỉ mới."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": " Dit apparaat kon het nieuwe certificaat niet verifiëren."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": " این دستگاه نتوانست گواهی جدید را تأیید کند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": " Этому устройству не удалось проверить новый сертификат."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": " Den här enheten kunde inte verifiera det nya certifikatet."
          }
        }
      }
    },
