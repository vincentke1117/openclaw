    "Enable Gateway TLS, or enter your Tailscale Serve HTTPS host in Manual Setup. Use Unencrypted only with a trusted private-LAN address.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable Gateway TLS, or enter your Tailscale Serve HTTPS host in Manual Setup. Use Unencrypted only with a trusted private-LAN address."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "启用 Gateway TLS，或在手动设置中输入您的 Tailscale Serve HTTPS 主机。仅在受信任的专用局域网地址上使用未加密连接。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "啟用 Gateway TLS，或在手動設定中輸入你的 Tailscale Serve HTTPS 主機。僅在受信任的私人區網位址下使用未加密連線。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Ative o TLS do Gateway ou informe seu host HTTPS do Tailscale Serve na Configuração Manual. Use Não criptografado apenas com um endereço de LAN privada confiável."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Aktivieren Sie Gateway-TLS oder geben Sie Ihren Tailscale Serve HTTPS-Host in der manuellen Einrichtung ein. Verwenden Sie „Unverschlüsselt“ nur mit einer vertrauenswürdigen Adresse im privaten LAN."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Habilita el TLS del Gateway o introduce tu host HTTPS de Tailscale Serve en Configuración manual. Usa Sin cifrar solo con una dirección de LAN privada de confianza."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway の TLS を有効にするか、手動セットアップで Tailscale Serve の HTTPS ホストを入力してください。信頼できるプライベート LAN アドレスの場合にのみ暗号化なしを使用してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway TLS를 활성화하거나 수동 설정에서 Tailscale Serve HTTPS 호스트를 입력하세요. 암호화되지 않음은 신뢰할 수 있는 사설 LAN 주소에서만 사용하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Activez le TLS de la Gateway, ou saisissez votre hôte HTTPS Tailscale Serve dans la Configuration manuelle. N'utilisez Non chiffré qu'avec une adresse LAN privée de confiance."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway TLS सक्षम करें, या Manual Setup में अपना Tailscale Serve HTTPS होस्ट दर्ज करें। Unencrypted का उपयोग केवल किसी विश्वसनीय निजी-LAN पते के साथ करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "فعّل TLS الخاص بـ Gateway، أو أدخل مضيف HTTPS الخاص بـ Tailscale Serve في الإعداد اليدوي. استخدم غير المشفّر فقط مع عنوان شبكة محلية خاصة موثوق."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Abilita il TLS del Gateway o inserisci l'host HTTPS di Tailscale Serve in Configurazione manuale. Usa Non crittografato solo con un indirizzo LAN privato attendibile."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway TLS'yi etkinleştirin veya Manuel Kurulum'da Tailscale Serve HTTPS ana bilgisayarınızı girin. Şifresiz seçeneğini yalnızca güvenilir bir özel LAN adresiyle kullanın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Увімкніть TLS для Gateway або введіть свій хост Tailscale Serve HTTPS у розділі «Ручне налаштування». Використовуйте нешифроване з'єднання лише з надійною адресою приватної локальної мережі."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Aktifkan TLS Gateway, atau masukkan host HTTPS Tailscale Serve Anda di Manual Setup. Gunakan Unencrypted hanya dengan alamat private-LAN yang tepercaya."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Włącz TLS Gateway lub podaj swój host HTTPS Tailscale Serve w konfiguracji ręcznej. Używaj opcji Niezaszyfrowane tylko z zaufanym adresem prywatnej sieci LAN."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "เปิดใช้งาน Gateway TLS หรือกรอกโฮสต์ HTTPS ของ Tailscale Serve ใน Manual Setup ใช้ Unencrypted เฉพาะกับที่อยู่ private-LAN ที่เชื่อถือได้เท่านั้น"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Bật Gateway TLS, hoặc nhập máy chủ HTTPS Tailscale Serve của bạn trong Thiết lập thủ công. Chỉ sử dụng Không mã hóa với địa chỉ LAN riêng đáng tin cậy."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Schakel Gateway TLS in, of voer je Tailscale Serve HTTPS-host in bij Handmatige installatie. Gebruik Onversleuteld alleen met een vertrouwd privé-LAN-adres."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "TLS مربوط به Gateway را فعال کنید، یا میزبان HTTPS مربوط به Tailscale Serve خود را در راه‌اندازی دستی وارد کنید. از حالت رمزنگاری‌نشده فقط با یک آدرس مورد اعتماد در شبکه محلی خصوصی استفاده کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Включите TLS для Gateway или укажите ваш HTTPS-хост Tailscale Serve в разделе «Ручная настройка». Используйте незашифрованное соединение только с доверенным адресом в частной локальной сети."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Aktivera Gateway-TLS, eller ange din Tailscale Serve HTTPS-värd i Manuell konfiguration. Använd endast okrypterat med en betrodd privat LAN-adress."
          }
        }
      }
    },
    "Enable Notifications to receive approval alerts while OpenClaw is not open.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable Notifications to receive approval alerts while OpenClaw is not open."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "启用通知，以便在 OpenClaw 未打开时接收审批提醒。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "啟用通知，以便在 OpenClaw 未開啟時接收核准提醒。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Ative as notificações para receber alertas de aprovação enquanto o OpenClaw não estiver aberto."
          }
        },
        "de": {
          "stringUnit": {
