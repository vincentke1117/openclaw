    "This disconnects, clears saved gateway credentials, and reopens onboarding.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This disconnects, clears saved gateway credentials, and reopens onboarding."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "这将断开连接、清除已保存的 Gateway 凭据，并重新打开引导流程。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "這會中斷連線、清除已儲存的 Gateway 憑證，並重新開啟新手引導。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Isso desconecta, limpa as credenciais salvas do gateway e reabre a integração."
          }
        },
        "de": {
          "stringUnit": {
