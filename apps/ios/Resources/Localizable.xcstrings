    "Camera, microphone, photos, contacts, calendar, and location may be available.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera, microphone, photos, contacts, calendar, and location may be available."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "可能会提供相机、麦克风、照片、联系人、日历和位置。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "相機、麥克風、照片、聯絡人、行事曆和位置資訊可能會可供使用。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Câmera, microfone, fotos, contatos, calendário e localização podem estar disponíveis."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Kamera, Mikrofon, Fotos, Kontakte, Kalender und Standort können verfügbar sein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "La cámara, el micrófono, las fotos, los contactos, el calendario y la ubicación pueden estar disponibles."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "カメラ、マイク、写真、連絡先、カレンダー、位置情報が利用可能になる場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "카메라, 마이크, 사진, 연락처, 캘린더, 위치를 사용할 수 있게 될 수 있습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "L’appareil photo, le microphone, les photos, les contacts, le calendrier et la localisation peuvent être disponibles."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "कैमरा, माइक्रोफ़ोन, फ़ोटो, संपर्क, कैलेंडर और स्थान उपलब्ध हो सकते हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "قد تتوفر الكاميرا والميكروفون والصور وجهات الاتصال والتقويم والموقع."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Fotocamera, microfono, foto, contatti, calendario e posizione potrebbero essere disponibili."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Kamera, mikrofon, fotoğraflar, kişiler, takvim ve konum kullanılabilir olabilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Можуть бути доступні камера, мікрофон, фото, контакти, календар і геолокація."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Kamera, mikrofon, foto, kontak, kalender, dan lokasi mungkin tersedia."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Dostępne mogą być aparat, mikrofon, zdjęcia, kontakty, kalendarz i lokalizacja."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "กล้อง ไมโครโฟน รูปภาพ รายชื่อ ปฏิทิน และตำแหน่งที่ตั้งอาจพร้อมใช้งาน"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Máy ảnh, micrô, ảnh, danh bạ, lịch và vị trí có thể khả dụng."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Camera, microfoon, foto's, contacten, agenda en locatie zijn mogelijk beschikbaar."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "دوربین، میکروفون، عکس‌ها، مخاطبان، تقویم و موقعیت مکانی ممکن است در دسترس باشند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Могут быть доступны камера, микрофон, фотографии, контакты, календарь и геопозиция."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Kamera, mikrofon, bilder, kontakter, kalender och plats kan vara tillgängliga."
          }
        }
      }
    },
    "Can't reach gateway at %1$@:%2$@. Check Tailscale or LAN.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can't reach gateway at %1$@:%2$@. Check Tailscale or LAN."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "无法连接到 %1$@:%2$@ 的 Gateway。请检查 Tailscale 或局域网。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "無法連線至 %1$@:%2$@ 的 Gateway。請檢查 Tailscale 或 LAN。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Não foi possível acessar o Gateway em %1$@:%2$@. Verifique o Tailscale ou a LAN."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Das Gateway unter %1$@:%2$@ ist nicht erreichbar. Überprüfe Tailscale oder das LAN."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "No se puede acceder al Gateway en %1$@:%2$@. Comprueba Tailscale o la LAN."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@:%2$@のGatewayに接続できません。TailscaleまたはLANを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@:%2$@의 Gateway에 연결할 수 없습니다. Tailscale 또는 LAN을 확인하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Impossible de joindre le Gateway à l’adresse %1$@:%2$@. Vérifiez Tailscale ou le réseau local."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@:%2$@ पर Gateway से संपर्क नहीं हो पा रहा है। Tailscale या LAN की जाँच करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "لا يمكن الوصول إلى Gateway على %1$@:%2$@. تحقّق من Tailscale أو LAN."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Impossibile raggiungere il Gateway all'indirizzo %1$@:%2$@. Controlla Tailscale o la LAN."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@:%2$@ adresindeki Gateway'e ulaşılamıyor. Tailscale'i veya LAN'ı kontrol edin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Не вдається підключитися до шлюзу за адресою %1$@:%2$@. Перевірте Tailscale або локальну мережу."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Tidak dapat menjangkau gateway di %1$@:%2$@. Periksa Tailscale atau LAN."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Nie można połączyć się z Gateway pod adresem %1$@:%2$@. Sprawdź Tailscale lub sieć LAN."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "ไม่สามารถเข้าถึง Gateway ที่ %1$@:%2$@ ได้ โปรดตรวจสอบ Tailscale หรือ LAN"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Không thể kết nối với Gateway tại %1$@:%2$@. Hãy kiểm tra Tailscale hoặc mạng LAN."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Kan de gateway op %1$@:%2$@ niet bereiken. Controleer Tailscale of het LAN."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "دسترسی به Gateway در %1$@:%2$@ ممکن نیست. Tailscale یا شبکه محلی را بررسی کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Не удаётся подключиться к Gateway по адресу %1$@:%2$@. Проверьте Tailscale или локальную сеть."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Det går inte att nå Gateway på %1$@:%2$@. Kontrollera Tailscale eller LAN."
          }
        }
      }
    },
    "Can't reach gateway at %1$@:%2$@. Verify Tailscale Serve is enabled and publishes this Gateway.": {
      "localizations": {
