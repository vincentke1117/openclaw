          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Eşleşen öneriler, gateway yenilendikten sonra burada görünür."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Відповідні пропозиції з’являться тут після оновлення gateway."
          }
        },
        "id": {
