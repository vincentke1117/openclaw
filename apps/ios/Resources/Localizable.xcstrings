        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "يؤدي هذا إلى إزالة بيانات الاعتماد المحفوظة والوصول إلى الجهاز وثقة TLS والمحادثات المخزنة مؤقتًا لهذا الـ Gateway."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Questo rimuove le credenziali salvate, l'accesso ai dispositivi, l'attendibilità TLS e le chat memorizzate nella cache per questo gateway."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Bu işlem, bu gateway için kaydedilen kimlik bilgilerini, cihaz erişimini, TLS güvenini ve önbelleğe alınmış sohbetleri kaldırır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Це видаляє збережені облікові дані, доступ пристрою, довіру TLS та кешовані чати для цього Gateway."
          }
        },
        "id": {
          "stringUnit": {
