            "value": "iPhone konnte nicht erreicht werden. Zum Wiederholen tippen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "No se pudo conectar con el iPhone. Toca para volver a intentarlo."
          }
