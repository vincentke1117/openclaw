    "Scan a setup QR code, paste a setup code, or choose a discovered gateway.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scan a setup QR code, paste a setup code, or choose a discovered gateway."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "扫描设置二维码，粘贴设置代码，或选择已发现的 Gateway。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "掃描設定 QR 碼、貼上設定碼，或選擇已探索到的 gateway。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Escaneie um código QR de configuração, cole um código de configuração ou escolha um gateway descoberto."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Scannen Sie einen Einrichtungs-QR-Code, fügen Sie einen Einrichtungscode ein oder wählen Sie ein erkanntes Gateway aus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Escanea un código QR de configuración, pega un código de configuración o elige un gateway detectado."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "セットアップQRコードをスキャンするか、セットアップコードを貼り付けるか、検出されたGatewayを選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "설정 QR 코드를 스캔하거나, 설정 코드를 붙여넣거나, 검색된 Gateway를 선택하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Scannez un code QR de configuration, collez un code de configuration ou choisissez une gateway découverte."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "सेटअप QR कोड स्कैन करें, सेटअप कोड पेस्ट करें, या खोजे गए Gateway को चुनें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "امسح رمز QR للإعداد، أو الصق رمز إعداد، أو اختر Gateway مكتشفًا."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Scansiona un codice QR di configurazione, incolla un codice di configurazione oppure scegli un gateway rilevato."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Kurulum QR kodu tarayın, kurulum kodu yapıştırın veya keşfedilen bir Gateway seçin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Відскануйте QR-код налаштування, вставте код налаштування або виберіть виявлений gateway."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Pindai kode QR penyiapan, tempel kode penyiapan, atau pilih gateway yang ditemukan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Zeskanuj kod QR konfiguracji, wklej kod konfiguracji albo wybierz wykryty gateway."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "สแกนรหัส QR สำหรับการตั้งค่า วางรหัสตั้งค่า หรือเลือก gateway ที่ค้นพบ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Quét mã QR thiết lập, dán mã thiết lập hoặc chọn một gateway đã được phát hiện."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Scan een QR-code voor configuratie, plak een configuratiecode of kies een gedetecteerde gateway."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "یک کد QR راه‌اندازی را اسکن کنید، یک کد راه‌اندازی را جای‌گذاری کنید، یا یک gateway شناسایی‌شده را انتخاب کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Отсканируйте QR-код настройки, вставьте код настройки или выберите обнаруженный Gateway."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Skanna en QR-konfigurationskod, klistra in en konfigurationskod eller välj en identifierad gateway."
          }
        }
      }
    },
