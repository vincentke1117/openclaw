    "TLS fingerprint verification timed out for %1$@:%2$@. Secure endpoint was reached, but TLS did not finish in time.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "TLS fingerprint verification timed out for %1$@:%2$@. Secure endpoint was reached, but TLS did not finish in time."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "验证 %1$@:%2$@ 的 TLS 指纹超时。已连接到安全端点，但 TLS 未能及时完成。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@:%2$@ 的 TLS 指紋驗證逾時。已連線至安全端點，但 TLS 未能及時完成。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "A verificação da impressão digital TLS atingiu o tempo limite para %1$@:%2$@. O endpoint seguro foi acessado, mas o TLS não foi concluído a tempo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Zeitüberschreitung bei der Überprüfung des TLS-Fingerabdrucks für %1$@:%2$@. Der sichere Endpunkt wurde erreicht, aber TLS konnte nicht rechtzeitig abgeschlossen werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Se agotó el tiempo de espera de la verificación de la huella TLS para %1$@:%2$@. Se accedió al punto de conexión seguro, pero TLS no finalizó a tiempo."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@:%2$@のTLSフィンガープリント検証がタイムアウトしました。セキュアエンドポイントには到達しましたが、TLSが時間内に完了しませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@:%2$@의 TLS 지문 확인 시간이 초과되었습니다. 보안 엔드포인트에는 연결되었지만 TLS가 제시간에 완료되지 않았습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "La vérification de l’empreinte TLS a expiré pour %1$@:%2$@. Le point de terminaison sécurisé a été atteint, mais la connexion TLS ne s’est pas terminée à temps."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@:%2$@ के लिए TLS फ़िंगरप्रिंट सत्यापन का समय समाप्त हो गया। सुरक्षित एंडपॉइंट तक पहुँचा गया था, लेकिन TLS समय पर पूरा नहीं हुआ।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "انتهت مهلة التحقق من بصمة TLS لـ %1$@:%2$@. تم الوصول إلى نقطة النهاية الآمنة، لكن TLS لم يكتمل في الوقت المحدد."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "La verifica dell'impronta digitale TLS per %1$@:%2$@ è scaduta. L'endpoint sicuro è stato raggiunto, ma TLS non è stato completato in tempo."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@:%2$@ için TLS parmak izi doğrulaması zaman aşımına uğradı. Güvenli uç noktaya ulaşıldı ancak TLS zamanında tamamlanmadı."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Час очікування перевірки відбитка TLS для %1$@:%2$@ минув. Захищеної кінцевої точки досягнуто, але TLS не завершив роботу вчасно."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Waktu verifikasi sidik jari TLS habis untuk %1$@:%2$@. Endpoint aman berhasil dijangkau, tetapi TLS tidak selesai tepat waktu."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Upłynął limit czasu weryfikacji odcisku palca TLS dla %1$@:%2$@. Nawiązano połączenie z bezpiecznym punktem końcowym, ale uzgadnianie TLS nie zakończyło się na czas."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "การตรวจสอบลายนิ้วมือ TLS สำหรับ %1$@:%2$@ หมดเวลา เข้าถึงปลายทางที่ปลอดภัยแล้ว แต่ TLS ดำเนินการไม่เสร็จทันเวลา"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Quá thời gian xác minh dấu vân tay TLS cho %1$@:%2$@. Đã kết nối được với điểm cuối bảo mật, nhưng TLS không hoàn tất kịp thời."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Er is een time-out opgetreden bij de verificatie van de TLS-vingerafdruk voor %1$@:%2$@. Het beveiligde eindpunt is bereikt, maar TLS is niet op tijd voltooid."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "مهلت تأیید اثر انگشت TLS برای %1$@:%2$@ به پایان رسید. به نقطه پایانی امن دسترسی پیدا شد، اما TLS به‌موقع تکمیل نشد."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Истекло время ожидания проверки отпечатка TLS для %1$@:%2$@. Защищённая конечная точка доступна, но установка TLS-соединения не завершилась вовремя."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Tidsgränsen för verifiering av TLS-fingeravtrycket överskreds för %1$@:%2$@. Den säkra slutpunkten nåddes, men TLS slutfördes inte i tid."
          }
        }
      }
    },
