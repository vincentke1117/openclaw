    "Realtime voice did not start. Talk is running with iOS speech recognition and TTS.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Realtime voice did not start. Talk is running with iOS speech recognition and TTS."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "实时语音未启动。对话功能正在使用 iOS 语音识别和 TTS。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "即時語音未啟動。Talk 正使用 iOS 語音辨識和 TTS 執行。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "A voz em tempo real não foi iniciada. O Talk está sendo executado com reconhecimento de fala e TTS do iOS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Echtzeit-Sprache konnte nicht gestartet werden. Talk verwendet die iOS-Spracherkennung und TTS."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "La voz en tiempo real no se inició. Talk se está ejecutando con el reconocimiento de voz y la síntesis de voz de iOS."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "リアルタイム音声を開始できませんでした。トークはiOS音声認識とTTSを使用して実行中です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "실시간 음성이 시작되지 않았습니다. Talk가 iOS 음성 인식 및 TTS를 사용하여 실행 중입니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "La voix en temps réel n’a pas démarré. Talk fonctionne avec la reconnaissance vocale et la synthèse vocale d’iOS."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "रीयलटाइम वॉइस शुरू नहीं हुई। Talk, iOS स्पीच रिकग्निशन और TTS के साथ चल रहा है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "لم يبدأ الصوت في الوقت الفعلي. تعمل المحادثة باستخدام التعرّف على الكلام وتحويل النص إلى كلام في iOS."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "La voce in tempo reale non è stata avviata. Talk è in esecuzione con il riconoscimento vocale e la sintesi vocale di iOS."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Gerçek zamanlı ses başlatılamadı. Konuşma, iOS konuşma tanıma ve TTS ile çalışıyor."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Голосовий режим реального часу не запустився. Розмова працює з розпізнаванням мовлення iOS і TTS."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Suara real-time tidak dimulai. Talk berjalan dengan pengenalan ucapan dan TTS iOS."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Głos w czasie rzeczywistym nie został uruchomiony. Funkcja rozmowy działa z rozpoznawaniem mowy i syntezą mowy iOS."
          }
        },
        "th": {
          "stringUnit": {
