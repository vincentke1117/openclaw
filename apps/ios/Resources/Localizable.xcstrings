    "Notifications have been denied. Enable them in iOS Settings.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Notifications have been denied. Enable them in iOS Settings."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "通知已被拒绝。请在 iOS 设置中启用。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "通知已被拒絕。請在 iOS 設定中啟用。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "As notificações foram negadas. Ative-as nos Ajustes do iOS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Benachrichtigungen wurden abgelehnt. Aktiviere sie in den iOS-Einstellungen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Se han denegado las notificaciones. Actívalas en Ajustes de iOS."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "通知が拒否されています。iOSの設定で有効にしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "알림이 거부되었습니다. iOS 설정에서 활성화하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Les notifications ont été refusées. Activez-les dans les Réglages iOS."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "सूचनाएँ अस्वीकृत कर दी गई हैं। उन्हें iOS Settings में सक्षम करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "تم رفض الإشعارات. فعّلها في إعدادات iOS."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Le notifiche sono state negate. Abilitale nelle Impostazioni di iOS."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Bildirimler reddedildi. Bunları iOS Ayarları'ndan etkinleştirin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Сповіщення заборонено. Увімкніть їх у Налаштуваннях iOS."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Notifikasi telah ditolak. Aktifkan di Pengaturan iOS."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Powiadomienia zostały odrzucone. Włącz je w Ustawieniach iOS."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "การแจ้งเตือนถูกปฏิเสธ เปิดใช้งานได้ในการตั้งค่า iOS"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Thông báo đã bị từ chối. Hãy bật chúng trong Cài đặt iOS."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Meldingen zijn geweigerd. Schakel ze in bij iOS-instellingen."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "اعلان‌ها رد شده‌اند. آن‌ها را در تنظیمات iOS فعال کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Уведомления запрещены. Включите их в настройках iOS."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Aviseringar har nekats. Aktivera dem i iOS-inställningarna."
          }
        }
      }
