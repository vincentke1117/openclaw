        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Thao tác này xóa thông tin đăng nhập đã lưu, quyền truy cập thiết bị, tin cậy TLS và các cuộc trò chuyện được lưu trong bộ nhớ đệm cho gateway này."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Hiermee worden opgeslagen inloggegevens, apparaattoegang, TLS-vertrouwen en gecachte chats voor deze gateway verwijderd."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "این کار اعتبارنامه‌های ذخیره‌شده، دسترسی دستگاه، اعتماد TLS و گفتگوهای ذخیره‌شده این gateway را حذف می‌کند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Это удалит сохранённые учётные данные, доступ устройства, доверие TLS и кэшированные чаты для этого Gateway."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Detta tar bort sparade autentiseringsuppgifter, enhetsåtkomst, TLS-förtroende och cachade chattar för denna gateway."
          }
        }
      }
    },
    "This resets the conversation for %@. The session key stays the same.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This resets the conversation for %@. The session key stays the same."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "这将重置与 %@ 的对话。会话密钥保持不变。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "這會重設與 %@ 的對話。工作階段金鑰將維持不變。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Isso redefine a conversa para %@. A chave da sessão permanece a mesma."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Dadurch wird die Unterhaltung für %@ zurückgesetzt. Der Sitzungsschlüssel bleibt unverändert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Esto reinicia la conversación para %@. La clave de sesión permanece igual."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "%@の会話がリセットされます。セッションキーは変更されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "%@의 대화가 초기화됩니다. 세션 키는 그대로 유지됩니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Cette opération réinitialise la conversation pour %@. La clé de session reste la même."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "यह %@ के लिए बातचीत रीसेट करता है। सेशन कुंजी वही रहती है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "سيؤدي هذا إلى إعادة تعيين المحادثة لـ %@. سيبقى مفتاح الجلسة كما هو."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Questa operazione reimposta la conversazione per %@. La chiave di sessione rimane invariata."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Bu işlem, %@ için konuşmayı sıfırlar. Oturum anahtarı aynı kalır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Це скине розмову для %@. Ключ сеансу залишиться незмінним."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Tindakan ini mengatur ulang percakapan untuk %@. Kunci sesi tetap sama."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Spowoduje to zresetowanie rozmowy dla %@. Klucz sesji pozostanie bez zmian."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "การดำเนินการนี้จะรีเซ็ตการสนทนาสำหรับ %@ โดยคีย์เซสชันจะยังคงเดิม"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Thao tác này sẽ đặt lại cuộc trò chuyện cho %@. Khóa phiên vẫn giữ nguyên."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Hiermee wordt het gesprek voor %@ gereset. De sessiesleutel blijft hetzelfde."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "با این کار مکالمه برای %@ بازنشانی می‌شود. کلید نشست بدون تغییر باقی می‌ماند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Это сбросит разговор для %@. Ключ сеанса останется прежним."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Detta återställer konversationen för %@. Sessionsnyckeln förblir densamma."
          }
        }
      }
    },
