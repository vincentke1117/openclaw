    "Ignored an expired direct connection setup. Send setup again from iPhone.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ignored an expired direct connection setup. Send setup again from iPhone."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "已忽略过期的直接连接设置。请从 iPhone 重新发送设置。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "已忽略過期的直接連線設定。請從 iPhone 再次傳送設定。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Uma configuração de conexão direta expirada foi ignorada. Envie a configuração novamente pelo iPhone."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Eine abgelaufene Einrichtung der Direktverbindung wurde ignoriert. Senden Sie die Einrichtung erneut vom iPhone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Se ignoró una configuración de conexión directa caducada. Vuelve a enviar la configuración desde el iPhone."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "期限切れの直接接続設定を無視しました。iPhoneから設定をもう一度送信してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "만료된 직접 연결 설정을 무시했습니다. iPhone에서 설정을 다시 보내세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Une configuration de connexion directe expirée a été ignorée. Renvoyez la configuration depuis l’iPhone."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "समाप्त हो चुके सीधे कनेक्शन सेटअप को अनदेखा किया गया। iPhone से सेटअप फिर से भेजें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "تم تجاهل إعداد اتصال مباشر منتهي الصلاحية. أرسل الإعداد مجددًا من iPhone."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "È stata ignorata una configurazione scaduta della connessione diretta. Invia nuovamente la configurazione da iPhone."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Süresi dolmuş bir doğrudan bağlantı kurulumu yok sayıldı. Kurulumu iPhone'dan tekrar gönderin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Прострочене налаштування прямого підключення проігноровано. Надішліть налаштування з iPhone ще раз."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Penyiapan koneksi langsung yang telah kedaluwarsa diabaikan. Kirim kembali penyiapan dari iPhone."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Zignorowano wygasłą konfigurację połączenia bezpośredniego. Wyślij konfigurację ponownie z iPhone’a."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "ละเว้นการตั้งค่าการเชื่อมต่อโดยตรงที่หมดอายุแล้ว โปรดส่งการตั้งค่าอีกครั้งจาก iPhone"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Đã bỏ qua một thiết lập kết nối trực tiếp hết hạn. Hãy gửi lại thiết lập từ iPhone."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Een verlopen configuratie voor een directe verbinding is genegeerd. Verstuur de configuratie opnieuw vanaf de iPhone."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "راه‌اندازی منقضی‌شدهٔ اتصال مستقیم نادیده گرفته شد. راه‌اندازی را دوباره از iPhone ارسال کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Просроченная настройка прямого подключения проигнорирована. Отправьте настройку повторно с iPhone."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "En utgången konfiguration för direktanslutning ignorerades. Skicka konfigurationen igen från iPhone."
          }
        }
      }
    },
