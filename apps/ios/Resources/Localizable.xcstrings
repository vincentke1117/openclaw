    "Secure handshake failed. Check Tailscale, then connect again.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Secure handshake failed. Check Tailscale, then connect again."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "安全握手失败。请检查 Tailscale，然后重新连接。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "安全交握失敗。請檢查 Tailscale，然後再次連線。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Falha na negociação segura. Verifique o Tailscale e conecte-se novamente."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Sicherer Handshake fehlgeschlagen. Überprüfen Sie Tailscale und stellen Sie dann erneut eine Verbindung her."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Error en el protocolo de enlace seguro. Comprueba Tailscale y vuelve a conectarte."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "セキュアハンドシェイクに失敗しました。Tailscaleを確認してから、もう一度接続してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "보안 핸드셰이크에 실패했습니다. Tailscale을 확인한 다음 다시 연결하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Échec de la négociation sécurisée. Vérifiez Tailscale, puis reconnectez-vous."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "सुरक्षित हैंडशेक विफल रहा। Tailscale जाँचें, फिर दोबारा कनेक्ट करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "فشلت المصافحة الآمنة. تحقّق من Tailscale، ثم اتصل مجددًا."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Handshake sicuro non riuscito. Controlla Tailscale, quindi connettiti di nuovo."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Güvenli el sıkışma başarısız oldu. Tailscale'i kontrol edin, ardından tekrar bağlanın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Не вдалося встановити захищене з’єднання. Перевірте Tailscale, а потім підключіться знову."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Handshake aman gagal. Periksa Tailscale, lalu hubungkan kembali."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Bezpieczne uzgadnianie połączenia nie powiodło się. Sprawdź Tailscale, a następnie połącz się ponownie."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "การจับมือแบบปลอดภัยล้มเหลว ตรวจสอบ Tailscale แล้วเชื่อมต่ออีกครั้ง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Bắt tay bảo mật không thành công. Hãy kiểm tra Tailscale, sau đó kết nối lại."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Beveiligde handshake mislukt. Controleer Tailscale en maak vervolgens opnieuw verbinding."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "دست‌دهی امن ناموفق بود. Tailscale را بررسی کنید، سپس دوباره متصل شوید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Не удалось установить безопасное соединение. Проверьте Tailscale, затем подключитесь снова."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Säker handskakning misslyckades. Kontrollera Tailscale och anslut sedan igen."
          }
        }
      }
    },
