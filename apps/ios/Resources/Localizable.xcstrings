        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Цей пристрій не довіряє TLS-сертифікату, наданому %@."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Perangkat ini tidak memercayai sertifikat TLS yang disajikan oleh %@."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "To urządzenie nie ufa certyfikatowi TLS przedstawionemu przez %@."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "อุปกรณ์นี้ไม่เชื่อถือใบรับรอง TLS ที่ %@ แสดง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Thiết bị này không tin cậy chứng chỉ TLS do %@ cung cấp."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Dit apparaat vertrouwt het TLS-certificaat dat door %@ wordt aangeboden niet."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "این دستگاه به گواهی TLS ارائه‌شده توسط %@ اعتماد ندارد."
          }
        },
        "ru": {
          "stringUnit": {
