    "Open Voice settings after the gateway loads Talk configuration.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Voice settings after the gateway loads Talk configuration."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway 加载 Talk 配置后，打开语音设置。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway 載入 Talk 設定後，開啟語音設定。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Abra os ajustes de Voz depois que o Gateway carregar a configuração do Talk."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Öffne die Spracheinstellungen, nachdem das Gateway die Talk-Konfiguration geladen hat."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Abre los ajustes de voz después de que el Gateway cargue la configuración de Talk."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "GatewayがTalk設定を読み込んだ後、音声設定を開いてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway에서 Talk 구성을 불러온 후 음성 설정을 여세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Ouvrez les réglages de la voix une fois que le Gateway a chargé la configuration Talk."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway द्वारा Talk कॉन्फ़िगरेशन लोड किए जाने के बाद वॉइस सेटिंग्स खोलें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "افتح إعدادات الصوت بعد أن يحمّل Gateway إعدادات Talk."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Apri le impostazioni Voce dopo che il Gateway ha caricato la configurazione di Talk."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway, Talk yapılandırmasını yükledikten sonra Ses ayarlarını açın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Відкрийте налаштування голосу після того, як шлюз завантажить конфігурацію Talk."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Buka pengaturan Suara setelah gateway memuat konfigurasi Talk."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
