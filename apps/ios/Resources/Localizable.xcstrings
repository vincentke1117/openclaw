    "Discovered gateways and manual setup live here when the gateway has not connected yet.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Discovered gateways and manual setup live here when the gateway has not connected yet."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "当 Gateway 尚未连接时，已发现的 Gateway 和手动设置会显示在这里。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "在 gateway 尚未連線時，探索到的閘道器和手動設定會顯示在這裡。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Gateways descobertos e configuração manual ficam aqui quando o gateway ainda não se conectou."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Entdeckte Gateways und die manuelle Einrichtung werden hier angezeigt, wenn das Gateway noch nicht verbunden ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Los gateways descubiertos y la configuración manual aparecen aquí cuando el gateway aún no se ha conectado."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "Gatewayがまだ接続されていない場合、検出されたGatewayと手動セットアップがここに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway가 아직 연결되지 않은 경우, 발견된 Gateway와 수동 설정이 여기에 표시됩니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Les gateways détectées et la configuration manuelle apparaissent ici lorsque la gateway n’est pas encore connectée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "जब Gateway अभी तक कनेक्ट नहीं हुआ हो, तो खोजे गए gateways और मैन्युअल सेटअप यहाँ दिखाई देते हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "تظهر هنا أجهزة Gateway المكتشفة والإعداد اليدوي عندما لا يكون Gateway متصلًا بعد."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "I gateway rilevati e la configurazione manuale compaiono qui quando il gateway non è ancora connesso."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway henüz bağlanmadığında keşfedilen Gateway'ler ve manuel kurulum burada yer alır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Виявлені gateway та ручне налаштування відображаються тут, коли gateway ще не підключено."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway yang ditemukan dan pengaturan manual akan muncul di sini saat Gateway belum terhubung."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Wykryte Gateway i konfiguracja ręczna pojawią się tutaj, gdy Gateway nie jest jeszcze połączony."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "Gateway ที่ค้นพบและการตั้งค่าด้วยตนเองจะแสดงที่นี่เมื่อ Gateway ยังไม่ได้เชื่อมต่อ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Các Gateway đã phát hiện và thiết lập thủ công sẽ hiển thị ở đây khi Gateway chưa kết nối."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Ontdekte gateways en handmatige configuratie staan hier wanneer de gateway nog niet is verbonden."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "Gatewayهای کشف‌شده و راه‌اندازی دستی زمانی اینجا نمایش داده می‌شوند که Gateway هنوز متصل نشده باشد."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Здесь отображаются обнаруженные Gateway и ручная настройка, пока Gateway еще не подключен."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Upptäckta Gateways och manuell konfiguration visas här när gatewayen inte har anslutit än."
          }
        }
      }
    },
