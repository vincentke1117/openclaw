            "value": "未报告最近的回忆、每日、已接地或阶段信号。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "未回報近期回想、每日、基礎或階段訊號。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Nenhum sinal recente de recall, diário, fundamentado ou de fase foi reportado."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Es wurden keine aktuellen Recall-, Tages-, Grounded- oder Phasensignale gemeldet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "No se han notificado señales recientes de recuerdo, diarias, fundamentadas o de fase."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "最近のリコール、日次、根拠付き、またはフェーズシグナルは報告されていません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
