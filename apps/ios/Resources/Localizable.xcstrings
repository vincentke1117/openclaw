    "Run app, permission, and gateway-adjacent checks without editing setup.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Run app, permission, and gateway-adjacent checks without editing setup."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "运行应用、权限以及 Gateway 相关检查，而不编辑设置。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "在不編輯設定的情況下執行 App、權限與 Gateway 相關檢查。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Execute verificações do app, de permissões e relacionadas ao gateway sem editar a configuração."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "App-, Berechtigungs- und Gateway-nahe Prüfungen ausführen, ohne die Einrichtung zu bearbeiten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Ejecuta comprobaciones de la app, permisos y aspectos relacionados con Gateway sin editar la configuración."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "設定を編集せずに、アプリ、権限、Gateway関連のチェックを実行します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "설정을 편집하지 않고 앱, 권한 및 게이트웨이 관련 검사를 실행합니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Exécutez des vérifications de l’app, des autorisations et liées à la Gateway sans modifier la configuration."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "सेटअप संपादित किए बिना ऐप, अनुमति, और Gateway-संबंधित जाँचें चलाएँ।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "تشغيل فحوصات التطبيق والأذونات وما يتعلق بـ Gateway دون تعديل الإعداد."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Esegui controlli dell'app, delle autorizzazioni e relativi al gateway senza modificare la configurazione."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Kurulumu düzenlemeden uygulama, izin ve Gateway bağlantılı kontrolleri çalıştırın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Запустіть перевірки застосунку, дозволів і пов’язані з Gateway перевірки без редагування налаштування."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
