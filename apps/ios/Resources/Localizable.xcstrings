    "Relay remains available; direct mode adds an independent Gateway node.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Relay remains available; direct mode adds an independent Gateway node."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "new",
            "value": "中继仍然可用；直连模式会添加一个独立的 Gateway 节点。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "new",
            "value": "中繼仍可使用；直連模式會新增一個獨立的 Gateway 節點。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "O relay permanece disponível; o modo direto adiciona um nó independente do Gateway."
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Relay bleibt verfügbar; der Direktmodus fügt einen unabhängigen Gateway-Knoten hinzu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "El relé sigue disponible; el modo directo añade un nodo de Gateway independiente."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "new",
            "value": "リレーは引き続き利用可能です。ダイレクトモードは独立した Gateway ノードを追加します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "릴레이는 계속 사용할 수 있으며, 직접 모드는 독립적인 Gateway 노드를 추가합니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Le relais reste disponible ; le mode direct ajoute un nœud Gateway indépendant."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "रिले उपलब्ध रहता है; डायरेक्ट मोड एक स्वतंत्र Gateway नोड जोड़ता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "يبقى التتابع متاحًا؛ يضيف الوضع المباشر عقدة Gateway مستقلة."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Il relay resta disponibile; la modalità diretta aggiunge un nodo Gateway indipendente."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "new",
            "value": "Aktarma kullanılabilir kalır; doğrudan mod bağımsız bir Gateway düğümü ekler."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "new",
            "value": "Ретрансляція залишається доступною; прямий режим додає незалежний вузол Gateway."
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Relay tetap tersedia; mode langsung menambahkan node Gateway independen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "new",
            "value": "Przekaźnik pozostaje dostępny; tryb bezpośredni dodaje niezależny węzeł Gateway."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "รีเลย์ยังคงใช้งานได้ โหมดตรงจะเพิ่มโหนด Gateway อิสระ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Relay vẫn khả dụng; chế độ trực tiếp bổ sung một nút Gateway độc lập."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "new",
            "value": "Relay blijft beschikbaar; directe modus voegt een onafhankelijke Gateway-node toe."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "new",
            "value": "رله همچنان در دسترس است؛ حالت مستقیم یک گره Gateway مستقل اضافه می‌کند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Реле остаётся доступным; прямой режим добавляет независимый узел Gateway."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "new",
            "value": "Relä förblir tillgängligt; direktläge lägger till en oberoende Gateway-nod."
          }
        }
      }
    },
